generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum FinancialItemType {
  INCOME
  EXPENSE
  FIXED_EXPENSE
  EXTRA_EXPENSE
  FIXED_INCOME
  EXTRA_INCOME
}

enum RecurrenceType {
  NONE
  DAILY
  WEEKLY
  MONTHLY
  YEARLY
}

enum PaymentStatus {
  PENDENTE
  PAGO
  ATRASADO
  CANCELADO
}

enum FinancialGoalStatus {
  ACTIVE
  COMPLETED
  CANCELED
}

model User {
  id            String          @id @default(uuid())
  name          String
  email         String          @unique
  password_hash String
  items         FinancialItem[]
  categories    FinancialCategory[]
  savings       Savings[]
  goals         FinancialGoal[]
  financialCategoriesInitialized Boolean @default(false)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
}

model FinancialCategory {
  id        String            @id @default(uuid())
  userId    String
  user      User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  type      FinancialItemType
  color     String            @default("#64748B")
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  @@unique([userId, type, name])
  @@index([userId])
  @@index([type])
}

model Savings {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title       String
  description String?
  amount      Decimal  @db.Decimal(12, 2)
  date        DateTime
  month       Int
  year        Int
  goalId      String?
  goal        FinancialGoal? @relation(fields: [goalId], references: [id], onDelete: SetNull)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
  @@index([date])
  @@index([goalId])
  @@index([userId, year])
  @@index([userId, year, month])
  @@index([userId, date])
}

model FinancialGoal {
  id            String              @id @default(uuid())
  userId        String
  user          User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  title         String
  description   String?
  targetAmount  Decimal             @db.Decimal(12, 2)
  currentAmount Decimal             @default(0) @db.Decimal(12, 2)
  startDate     DateTime
  targetDate    DateTime?
  category      String?
  status        FinancialGoalStatus @default(ACTIVE)
  savings       Savings[]
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  @@index([userId])
  @@index([status])
  @@index([targetDate])
  @@index([userId, status])
}

model FinancialItem {
  id          String            @id @default(uuid())
  userId      String
  user        User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  title       String
  name        String
  description String?
  amount      Decimal           @db.Decimal(12, 2)
  type        FinancialItemType
  category    String
  dueDate     DateTime?
  paymentDate DateTime?
  status      PaymentStatus     @default(PENDENTE)
  dueDay      Int?
  isFixed     Boolean           @default(false)
  recurrenceType RecurrenceType @default(NONE)
  recurrenceGroupId String?
  date        DateTime
  month       Int
  year        Int
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@index([userId])
  @@index([type])
  @@index([status])
  @@index([date])
  @@index([recurrenceGroupId])
  @@index([userId, year])
  @@index([userId, year, month])
  @@index([userId, date])
}
