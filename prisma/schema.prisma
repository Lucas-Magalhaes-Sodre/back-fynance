generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum FinancialItemType {
  INCOME
  EXPENSE
  INVESTMENT
  FIXED_EXPENSE
  EXTRA_EXPENSE
  FIXED_INCOME
  EXTRA_INCOME
}

enum RecurrenceType {
  NONE
  DAILY
  WEEKLY
  MONTHLY
  YEARLY
}

enum PaymentStatus {
  PENDENTE
  PAGO
  ATRASADO
  CANCELADO
}

enum FinancialGoalStatus {
  ACTIVE
  COMPLETED
  CANCELED
}

enum ReminderStatus {
  PENDING
  READ
  DISMISSED
}

model User {
  id            String          @id @default(uuid())
  name          String
  email         String          @unique
  password_hash String
  phone         String?
  city          String?
  occupation    String?
  lgpdAcceptedAt DateTime?
  lgpdConsentVersion String?
  marketingConsent Boolean @default(false)
  dataDeletionRequestedAt DateTime?
  items         FinancialItem[]
  categories    FinancialCategory[]
  savings       Savings[]
  goals         FinancialGoal[]
  creditCards   CreditCard[]
  creditCardPurchases CreditCardPurchase[]
  reminders     FinancialReminder[]
  pushTokens    PushToken[]
  financialCategoriesInitialized Boolean @default(false)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
}

model PushToken {
  id         String   @id @default(uuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token      String   @unique
  platform   String?
  deviceName String?
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([userId])
  @@index([isActive])
}

model CookieConsent {
  id          String   @id @default(uuid())
  visitorId   String
  version     String
  necessary   Boolean  @default(true)
  preferences Boolean  @default(false)
  analytics   Boolean  @default(false)
  marketing   Boolean  @default(false)
  sourcePath  String?
  createdAt   DateTime @default(now())

  @@index([visitorId])
  @@index([createdAt])
}

model FinancialCategory {
  id        String            @id @default(uuid())
  userId    String
  user      User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  type      FinancialItemType
  color     String            @default("#64748B")
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  @@unique([userId, type, name])
  @@index([userId])
  @@index([type])
}

model Savings {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title       String
  category    String   @default("Outros")
  color       String   @default("#D4A017")
  description String?
  amount      Decimal  @db.Decimal(12, 2)
  date        DateTime
  month       Int
  year        Int
  isFixed     Boolean  @default(false)
  recurrenceType RecurrenceType @default(NONE)
  recurrenceGroupId String?
  goalId      String?
  hasYield    Boolean  @default(false)
  yieldRateMonthly Decimal? @db.Decimal(7, 4)
  goal        FinancialGoal? @relation(fields: [goalId], references: [id], onDelete: SetNull)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
  @@index([date])
  @@index([goalId])
  @@index([userId, year])
  @@index([userId, year, month])
  @@index([userId, date])
  @@index([recurrenceGroupId])
}

model FinancialGoal {
  id            String              @id @default(uuid())
  userId        String
  user          User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  title         String
  description   String?
  targetAmount  Decimal             @db.Decimal(12, 2)
  currentAmount Decimal             @default(0) @db.Decimal(12, 2)
  startDate     DateTime
  targetDate    DateTime?
  category      String?
  imageUrl      String?
  imageUrls     String[]            @default([])
  color         String              @default("#0F766E")
  hasYield      Boolean             @default(false)
  yieldRateMonthly Decimal?         @db.Decimal(7, 4)
  status        FinancialGoalStatus @default(ACTIVE)
  savings       Savings[]
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  @@index([userId])
  @@index([status])
  @@index([targetDate])
  @@index([userId, status])
}

model FinancialItem {
  id          String            @id @default(uuid())
  userId      String
  user        User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  title       String
  name        String
  description String?
  amount      Decimal           @db.Decimal(12, 2)
  type        FinancialItemType
  category    String
  dueDate     DateTime?
  paymentDate DateTime?
  status      PaymentStatus     @default(PENDENTE)
  dueDay      Int?
  isFixed     Boolean           @default(false)
  recurrenceType RecurrenceType @default(NONE)
  recurrenceGroupId String?
  reminders   FinancialReminder[]
  date        DateTime
  month       Int
  year        Int
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@index([userId])
  @@index([type])
  @@index([status])
  @@index([date])
  @@index([recurrenceGroupId])
  @@index([userId, year])
  @@index([userId, year, month])
  @@index([userId, date])
}

model FinancialReminder {
  id              String         @id @default(uuid())
  userId          String
  user            User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  financialItemId String
  financialItem   FinancialItem  @relation(fields: [financialItemId], references: [id], onDelete: Cascade)
  title           String
  message         String?
  remindAt        DateTime
  offsetDays      Int?
  status          ReminderStatus @default(PENDING)
  sentAt          DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@index([userId])
  @@index([financialItemId])
  @@index([remindAt])
  @@index([sentAt])
  @@index([userId, status, remindAt])
}

model CreditCard {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  dueDay    Int
  creditLimit Decimal? @db.Decimal(12, 2)
  isActive  Boolean  @default(true)
  color     String   @default("#0F766E")
  purchases CreditCardPurchase[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, name])
  @@index([userId])
}

model CreditCardPurchase {
  id          String     @id @default(uuid())
  userId      String
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  cardId      String
  card        CreditCard @relation(fields: [cardId], references: [id], onDelete: Cascade)
  title       String
  description String?
  amount      Decimal    @db.Decimal(12, 2)
  purchaseDate DateTime
  installments Int       @default(1)
  skippedInstallments Int[] @default([])
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([userId])
  @@index([cardId])
  @@index([purchaseDate])
  @@index([userId, cardId])
}
